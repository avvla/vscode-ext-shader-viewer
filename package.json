{
  "name": "visual-synth-shader-viewer",
  "displayName": "Visual Synth Shader Viewer",
  "description": "Preview and debug Visual Synth 2 .frag shader files in VS Code",
  "version": "0.2.0",
  "icon": "synth-icon.png",
  "license": "MIT",
  "publisher": "Avvla",
  "author": {
    "name": "Lisa Wagner",
    "url": "https://github.com/avvla"
  },
    "repository": {
    "type": "git",
    "url": "https://github.com/avvla/vscode-ext-shader-viewer.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization",
    "Debuggers"
  ],
  "activationEvents": [
    "workspaceContains:**/*.frag"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "glsl",
        "aliases": ["GLSL", "OpenGL Shading Language"],
        "extensions": [".glsl", ".vert", ".frag", ".geom", ".tesc", ".tese", ".comp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "glsl",
        "scopeName": "source.glsl",
        "path": "./syntaxes/glsl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "visualSynthShaderViewer.preview",
        "title": "Visual Synth: Preview Shader",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .frag",
          "command": "visualSynthShaderViewer.preview",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .frag",
          "command": "visualSynthShaderViewer.preview",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "visualSynthShaderViewer.preview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .frag"
      }
    ],
    "configuration": {
      "title": "Visual Synth Shader Viewer",
      "properties": {
        "visualSynthShaderViewer.glslangValidatorPath": {
          "type": "string",
          "default": "glslangValidator",
          "description": "Path to the glslangValidator executable used for GLSL linting. Defaults to 'glslangValidator' (assumes it is on your system PATH via the Vulkan SDK). Set to a full path if needed, e.g. 'C:/VulkanSDK/1.3.x/Bin/glslangValidator.exe'."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.x",
    "@typescript-eslint/parser": "^5.x",
    "eslint": "^8.x",
    "typescript": "^5.0.0"
  }
}
