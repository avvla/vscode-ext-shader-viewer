{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*\\{[^}\"']*$",
        "decreaseIndentPattern": "^\\s*\\}"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*/\\*\\*(?!/)([^*]|\\*(?!/))*$",
            "action": { "indent": "indentOutdent", "appendText": " * " }
        },
        {
            "beforeText": "^\\s* \\*(?!/)([^*]|\\*(?!/))*$",
            "action": { "indent": "none", "appendText": "* " }
        }
    ]
}
